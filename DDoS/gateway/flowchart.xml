<mxfile>
  <diagram name="DDoS Flowchart">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Client Request -->
        <mxCell id="client" value="Client Request" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="100" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Gateway -->
        <mxCell id="gateway" value="Gateway Receives Request" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="180" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Logging -->
        <mxCell id="log" value="Log Traffic Data" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="260" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Feature Extraction -->
        <mxCell id="features" value="Feature Extraction&#xa;req_count, avg_gap, unique_urls" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- ML Model -->
        <mxCell id="ml" value="ML Model Prediction&#xa;Random Forest" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Is Attack?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="520" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Block -->
        <mxCell id="block" value="Block Request (429)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="620" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Forward -->
        <mxCell id="forward" value="Forward to Web App" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="620" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Response -->
        <mxCell id="response" value="Send Response to Client" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="720" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="810" width="120" height="60" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>